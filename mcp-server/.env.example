# NeoMint MCP Server Configuration

# Logging level: DEBUG, INFO, WARNING, ERROR
NEOMINT_LOG_LEVEL=INFO

# Require user confirmation before destructive operations (write_file, run_command)
NEOMINT_CONFIRM_DESTRUCTIVE=true

# Maximum file size (bytes) that read_file will return (default: 1 MB)
NEOMINT_MAX_FILE_READ_BYTES=1048576

# Maximum timeout (seconds) for run_command execution
NEOMINT_MAX_COMMAND_TIMEOUT=30
